{
  "name": "typescript-api-autotests",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "playwright",
    "typescript",
    "zod",
    "allure"
  ],
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "allure:clear": "rm -rf allure-report allure-results",
    "allure:report": "bunx allure generate allure-results && bunx allure open",
    "biome:fix": "bunx @biomejs/biome check --write --unsafe .",
    "biome:no-fix": "bunx @biomejs/biome check .",
    "build:check": "tsc --noEmit --skipLibCheck",
    "preinstall": "npx --yes only-allow bun",
    "lint-staged": "lint-staged",
    "pre-push": "bun run build:check",
    "precommit": "check-exact package.json && lint-staged && bun run build:check && git add package.json",
    "prepare": "husky",
    "prepare-commit": "bun run ./utils/prepareCommitMessage.ts",
    "test": "bunx playwright test",
    "test:local": "bun run test --workers=1",
    "utils:docker-build": "docker build -f Dockerfile-base -t playwright-bun:latest .",
    "utils:docker-run-tests": "bun run ./utils/dockerRunTests/index.ts",
    "zod:generate": "openapi-zod-client http://localhost:8000/openapi.json -o ./schemas/generated.ts -t schemas/templates/schemas-only.hbs --export-schemas --with-description"
  },
  "lint-staged": {
    "package.json": "sort-package-json",
    "*.{ts,js,json,md}": [
      "biome check --write --unsafe"
    ]
  },
  "dependencies": {
    "@faker-js/faker": "10.3.0",
    "@playwright/test": "1.58.2",
    "allure-js-commons": "3.5.0",
    "allure-playwright": "3.5.0",
    "config": "4.4.1",
    "dayjs": "1.11.19",
    "enquirer": "2.4.1",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "openapi-zod-client": "1.18.3",
    "sort-package-json": "3.6.1",
    "typescript": "5.9.3",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "1.3.10",
    "@types/config": "3.3.5",
    "@types/node": "25.3.3",
    "@types/uuid": "11.0.0",
    "check-exact": "1.1.0",
    "globals": "17.4.0"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": "22.14.0"
  }
}
